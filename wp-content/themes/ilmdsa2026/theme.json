            {
              "fontFamily": "\"Manifold DSA\"",
              "fontStyle": "normal",
              "fontWeight": "300",
              "src": [
                "file:./assets/fonts/manifold-dsa/manifold-dsa-300-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"Manifold DSA\"",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/manifold-dsa/manifold-dsa-400-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"Manifold DSA\"",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": [
                "file:./assets/fonts/manifold-dsa/manifold-dsa-500-normal.woff2"
              ]
            },
            {
              "fontFamily": "\"Manifold DSA\"",
              "fontStyle": "italic",
              "fontWeight": "300",
              "src": [
                "file:./assets/fonts/manifold-dsa/manifold-dsa-300-italic.woff2"
