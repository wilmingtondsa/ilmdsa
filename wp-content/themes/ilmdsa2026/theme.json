        {
          "color": "#231f20",
          "name": "Black",
          "slug": "custom-black"
        },
        {
          "color": "#ffffff",
          "name": "White",
          "slug": "custom-white"
        },
        {
          "color": "#c6cf4f",
          "name": "Flytrap Green",
          "slug": "custom-flytrap-green"
